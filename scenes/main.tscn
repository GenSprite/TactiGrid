[ext_resource type="Script" uid="uid://cm8o3vxmy0b8x" path="res://scripts/GridManager.gd" id="1_grid"]
[ext_resource type="Script" uid="uid://b41eserawcou"   path="res://scripts/GameManager.gd" id="2_game"]
[ext_resource type="Script" uid="uid://cqd8lia0gr66a"  path="res://scripts/AIController.gd" id="3_ai"]
[ext_resource type="Script" uid="uid://1gxo80cyibql"   path="res://scripts/UIManager.gd"   id="4_ui"]

; ── Root ──────────────────────────────────────────────────────────────
[node name="Main" type="Node2D"]
position = Vector2(0, 0)

; ── Grid ──────────────────────────────────────────────────────────────
[node name="GridManager" type="Node2D" parent="."]
script = ExtResource("1_grid")

; ── Game logic ────────────────────────────────────────────────────────
[node name="GameManager" type="Node" parent="."]
script = ExtResource("2_game")

[node name="AIController" type="Node" parent="GameManager"]
script = ExtResource("3_ai")

; ── UI (CanvasLayer so it renders above the game world) ───────────────
[node name="UIManager" type="CanvasLayer" parent="GameManager"]
script = ExtResource("4_ui")

[node name="TurnLabel" type="Label" parent="GameManager/UIManager"]
offset_left   = 10.0
offset_top    = 10.0
offset_right  = 220.0
offset_bottom = 42.0
theme_override_font_sizes/font_size = 16
text = "Player Turn"

[node name="EndTurnButton" type="Button" parent="GameManager/UIManager"]
offset_left   = 556.0
offset_top    = 8.0
offset_right  = 694.0
offset_bottom = 46.0
text = "End Turn"

; ── Unit info panel (bottom-left) ────────────────────────────────────
[node name="UnitInfoPanel" type="PanelContainer" parent="GameManager/UIManager"]
offset_left   = 10.0
offset_top    = 476.0
offset_right  = 230.0
offset_bottom = 592.0

[node name="UnitInfoLabel" type="Label" parent="GameManager/UIManager/UnitInfoPanel"]
layout_mode = 2
theme_override_font_sizes/font_size = 11
text = "Select a unit"
horizontal_alignment = 0

; ── Game-over overlay (centred) ───────────────────────────────────────
[node name="GameOverPanel" type="PanelContainer" parent="GameManager/UIManager"]
anchors_preset  = 8
anchor_left     = 0.5
anchor_top      = 0.5
anchor_right    = 0.5
anchor_bottom   = 0.5
offset_left     = -130.0
offset_top      = -70.0
offset_right    = 130.0
offset_bottom   = 70.0
grow_horizontal = 2
grow_vertical   = 2
visible         = false

[node name="VBox" type="VBoxContainer" parent="GameManager/UIManager/GameOverPanel"]
layout_mode = 2

[node name="ResultLabel" type="Label" parent="GameManager/UIManager/GameOverPanel/VBox"]
layout_mode = 2
theme_override_font_sizes/font_size = 22
horizontal_alignment = 1
text = ""

[node name="RestartButton" type="Button" parent="GameManager/UIManager/GameOverPanel/VBox"]
layout_mode = 2
text = "Play Again"
